# LiveKit (where the worker registers + which room secret to authenticate with).
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Agent name. Must match the dispatch name a JWT requests, otherwise no jobs
# get routed here. The orchestrator stamps tokens with this same value.
LIVEKIT_AGENT_NAME=nexus-voice-agent

# Google Gemini Live API. Get a key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Tavus Phoenix-4 BYO LLM mode. Replica + persona must be configured for
# pipeline_mode=echo and transport_type=livekit (see Tavus dashboard).
TAVUS_API_KEY=
TAVUS_REPLICA_ID=
TAVUS_PERSONA_ID=

# Where the agent forwards tool-call notifications + state transitions.
# Phase 4 wires start_build through this URL; Phase 3 only uses
# /api/avatar/state to mirror agent_state_changed events into Convex.
ORCHESTRATOR_URL=http://localhost:4000

# Exa /answer endpoint backs the web_search tool. Get a key at
# https://exa.ai/ (1000 free credits; ~$0.005/req after). If unset, the
# tool returns a graceful "not configured" string instead of erroring.
EXA_API_KEY=

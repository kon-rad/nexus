# Cursor SDK API key — never exposed to the browser.
CURSOR_API_KEY=

# Daytona API key + cloud endpoint.
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api

# Convex deployment — server-side mutation pusher.
# Use the deployment URL (same as NEXT_PUBLIC_CONVEX_URL) for HTTP client.
CONVEX_URL=https://your-deployment.convex.cloud

# Optional: Convex deploy key for CI/CD.
CONVEX_DEPLOY_KEY=

# HTTP listen port for the orchestrator.
PORT=4000

# Workspace scratch dir where Cursor local agents run.
# Per-session subdirectories are created under this path.
ORCHESTRATOR_WORKDIR=/tmp/nexus-orchestrator

# --- Phase 3: voice + avatar ---
# LiveKit server. In dev, `docker run livekit/livekit-server --dev` uses
# placeholder keys: devkey / secret. The browser only sees LIVEKIT_URL via
# NEXT_PUBLIC_LIVEKIT_URL — never the API secret.
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Optional: agent name for explicit dispatch via JWT roomConfig. Phase 3 dev
# leaves this unset so the LiveKit Agent worker auto-joins every room (the
# livekit-server v1.11 JWT JSON parser rejects RoomAgentDispatch.deployment
# from livekit-server-sdk 2.15+). Phase 4 reintroduces this with
# AgentDispatchClient over Twirp.
# LIVEKIT_AGENT_NAME=nexus-voice-agent

# Convex client URL — safe to expose to the browser.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Orchestrator URL the dev prompt bar calls.
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:4000

# Phase-2-only: set to "1" to render the workspace dev prompt bar.
NEXT_PUBLIC_DEV_PROMPT_BAR=1

# Phase 3 — LiveKit WebSocket URL. Public-safe (auth is via JWT from orchestrator).
# Local dev with `docker run livekit/livekit-server --dev`: ws://localhost:7880
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880
